APP_NAME="ZEHINLI YOLDASH LOGISTICS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://zehinliyoldash.com

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_TIMEZONE=Asia/Ashgabat

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
